# Set to `production` to disable live-reload and mount less
SMOKESIGNALS_ENV=development

# --- Docker images ---
# By default, `docker compose up` pulls the pre-built multi-arch images from DockerHub.
# Override IMAGE_TAG to pin to a specific commit (e.g. IMAGE_TAG=abc1234), or
# run `docker compose build` to build locally from source (the local build will
# be tagged with the same image name so subsequent `up` calls use it).
BACKEND_IMAGE=jivandabeast/smokesignals-backend
FRONTEND_IMAGE=jivandabeast/smokesignals-frontend
IMAGE_TAG=latest

# --- Development-only bind mounts ---
# In development, set SMOKESIGNALS_ENV_MOUNT_BACKEND=./backend/app and
# SMOKESIGNALS_ENV_MOUNT_FRONTEND=./frontend so your source is mounted into the
# containers for live reload. In production, unset them (they'll no-op) so the
# containers run the image content as shipped.

# JWT signing secret for local auth (change in production!)
SMOKESIGNALS_SECRET_KEY=dev-secret-change-me

# CORS: comma-separated list, or *
SMOKESIGNALS_CORS_ORIGINS=*

# --- Optional: Cloudflare Zero Trust JWT verification ---
# When enabled, requests carrying a Cf-Access-Jwt-Assertion header (or Bearer token from /api/auth/cf-exchange)
# will be verified against Cloudflare's JWKS. Certs are cached for 24h.
SMOKESIGNALS_CLOUDFLARE_ACCESS_ENABLED=false
# Set your team domain (either "myteam" or "myteam.cloudflareaccess.com" or full https URL)
SMOKESIGNALS_CLOUDFLARE_TEAM_DOMAIN=
# Application audience (AUD) from your Cloudflare Access application
SMOKESIGNALS_CLOUDFLARE_AUDIENCE=

# --- Optional: Web Push (generate with `npx web-push generate-vapid-keys`) ---
SMOKESIGNALS_VAPID_PUBLIC_KEY=
SMOKESIGNALS_VAPID_PRIVATE_KEY=
SMOKESIGNALS_VAPID_CONTACT_EMAIL=admin@smokesignals.local
